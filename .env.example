# Conexión a PostgreSQL (con pgvector instalado)
DATABASE_URL=postgresql://usuario:password@localhost:5432/vector_memory_db

# OpenAI API Key — para generar embeddings con text-embedding-3-small
OPENAI_API_KEY=tu_openai_api_key_aqui

# Rutas locales del agente (ajustar según tu setup)
SESSIONS_DIR=/ruta/a/tus/sesiones
MEMORY_DIR=/ruta/a/tu/carpeta/memory
MEMORY_FILE=/ruta/a/tu/MEMORY.md
